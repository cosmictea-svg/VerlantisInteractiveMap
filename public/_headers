# Cloudflare Pages cache + security headers

# Security headers on every route
/*
  X-Frame-Options: DENY
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: camera=(), microphone=(), geolocation=()

# HTML entry point — always revalidate so mobile browsers pick up new JS bundles
/*.html
  Cache-Control: no-cache, no-store, must-revalidate

# Root (index.html served at /)
/
  Cache-Control: no-cache, no-store, must-revalidate

# Vite hashed assets (JS/CSS chunks) — safe to cache long-term because filenames change on every build
/assets/*
  Cache-Control: public, max-age=31536000, immutable
